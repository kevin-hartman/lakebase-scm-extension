{
  "name": "lakebase-scm-extension",
  "displayName": "Lakebase SCM Extension",
  "description": "Unified visibility into code and database branch changes for Databricks Lakebase",
  "version": "0.4.1",
  "publisher": "databricks-field-eng",
  "icon": "resources/icons/extension-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevin-hartman/lakebase-scm-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "onView:lakebaseBranches",
    "workspaceContains:.env",
    "workspaceContains:.env.example"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lakebase-synced-scm",
          "title": "Lakebase SCM Extension",
          "icon": "resources/icons/lakebase-sidebar.svg"
        }
      ]
    },
    "views": {
      "lakebase-synced-scm": [
        {
          "id": "lakebaseBranches",
          "name": "Project"
        },
        {
          "id": "lakebaseChanges",
          "name": "Changes"
        },
        {
          "id": "lakebaseMigrations",
          "name": "Schema Migrations",
          "when": "!lakebaseSync.onFeatureBranch"
        },
        {
          "id": "lakebasePR",
          "name": "Pull Request",
          "when": "lakebaseSync.hasPR"
        },
        {
          "id": "lakebaseRunner",
          "name": "CI Runner"
        },
        {
          "id": "lakebaseMerges",
          "name": "Recent Merges",
          "when": "!lakebaseSync.onFeatureBranch"
        },
        {
          "id": "lakebaseGraph",
          "name": "Graph",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "lakebaseSync.showBranchStatus",
        "title": "Show Branch Status"
      },
      {
        "command": "lakebaseSync.connectWorkspace",
        "title": "Connect to Workspace",
        "icon": "$(globe)"
      },
      {
        "command": "lakebaseSync.refreshBranches",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "lakebaseSync.createBranch",
        "title": "Create Lakebase Branch",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lakebaseSync.createUnifiedBranch",
        "title": "Create Branch...",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "lakebaseSync.deleteBranch",
        "title": "Delete Branch..."
      },
      {
        "command": "lakebaseSync.refreshCredentials",
        "title": "Refresh Database Credentials",
        "icon": "$(refresh)"
      },
      {
        "command": "lakebaseSync.runMigrate",
        "title": "Run Flyway Migrate"
      },
      {
        "command": "lakebaseSync.showMigrationHistory",
        "title": "Show Migration History"
      },
      {
        "command": "lakebaseSync.showTableDiff",
        "title": "Schema Diff"
      },
      {
        "command": "lakebaseSync.showBranchDiff",
        "title": "Branch Diff Summary",
        "icon": "$(diff)"
      },
      {
        "command": "lakebaseSync.moreActions",
        "title": "More Actions...",
        "icon": "$(ellipsis)"
      },
      {
        "command": "lakebaseSync.showCachedBranchDiff",
        "title": "Branch Diff (Cached)"
      },
      {
        "command": "lakebaseSync.switchBranch",
        "title": "Switch to Branch",
        "icon": "$(arrow-right)"
      },
      {
        "command": "lakebaseSync.openInConsole",
        "title": "Open in Databricks Console",
        "icon": "$(link-external)"
      },
      {
        "command": "lakebaseSync.stageFile",
        "title": "Stage",
        "icon": "$(add)"
      },
      {
        "command": "lakebaseSync.unstageFile",
        "title": "Unstage",
        "icon": "$(remove)"
      },
      {
        "command": "lakebaseSync.discardChanges",
        "title": "Discard Changes",
        "icon": "$(discard)"
      },
      {
        "command": "lakebaseSync.stageAll",
        "title": "Stage All",
        "icon": "$(add)"
      },
      {
        "command": "lakebaseSync.unstageAll",
        "title": "Unstage All",
        "icon": "$(remove)"
      },
      {
        "command": "lakebaseSync.commit",
        "title": "Commit",
        "icon": "$(check)"
      },
      {
        "command": "lakebaseSync.push",
        "title": "Push",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "lakebaseSync.pull",
        "title": "Pull",
        "icon": "$(cloud-download)"
      },
      {
        "command": "lakebaseSync.publishBranch",
        "title": "Publish Branch...",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "lakebaseSync.sync",
        "title": "Sync",
        "icon": "$(sync)"
      },
      {
        "command": "lakebaseSync.reviewBranch",
        "title": "Review Branch",
        "icon": "$(compare-changes)"
      },
      {
        "command": "lakebaseSync.createPullRequest",
        "title": "Create Pull Request",
        "icon": "$(git-pull-request-create)"
      },
      {
        "command": "lakebaseSync.healthCheck",
        "title": "Health Check",
        "icon": "$(checklist)"
      },
      {
        "command": "lakebaseSync.switchBranchPicker",
        "title": "Create New Branch | Create Branch From | Switch Branch to...",
        "icon": "$(git-branch)"
      },
      {
        "command": "lakebaseSync.graphPickRepo",
        "title": "Select Repository",
        "icon": "$(repo)"
      },
      {
        "command": "lakebaseSync.graphPickRef",
        "title": "Filter Branch/Ref",
        "icon": "$(git-branch)"
      },
      {
        "command": "lakebaseSync.graphGoToCurrent",
        "title": "Go to Current History Item",
        "icon": "$(target)"
      },
      {
        "command": "lakebaseSync.graphFetchAll",
        "title": "Fetch from All Remotes",
        "icon": "$(cloud-download)"
      },
      {
        "command": "lakebaseSync.graphPull",
        "title": "Pull",
        "icon": "$(arrow-down)"
      },
      {
        "command": "lakebaseSync.graphPush",
        "title": "Push",
        "icon": "$(arrow-up)"
      },
      {
        "command": "lakebaseSync.graphRefresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "lakebaseSync.fetch",
        "title": "Fetch",
        "icon": "$(cloud-download)"
      },
      {
        "command": "lakebaseSync.stash",
        "title": "Stash",
        "icon": "$(archive)"
      },
      {
        "command": "lakebaseSync.stashPop",
        "title": "Pop Stash...",
        "icon": "$(archive)"
      },
      {
        "command": "lakebaseSync.commitStaged",
        "title": "Commit Staged"
      },
      {
        "command": "lakebaseSync.commitAll",
        "title": "Commit All"
      },
      {
        "command": "lakebaseSync.undoLastCommit",
        "title": "Undo Last Commit"
      },
      {
        "command": "lakebaseSync.commitAmend",
        "title": "Commit (Amend)"
      },
      {
        "command": "lakebaseSync.commitStagedAmend",
        "title": "Commit Staged (Amend)"
      },
      {
        "command": "lakebaseSync.commitAllAmend",
        "title": "Commit All (Amend)"
      },
      {
        "command": "lakebaseSync.discardAllChanges",
        "title": "Discard All Changes"
      },
      {
        "command": "lakebaseSync.deleteBranch",
        "title": "Delete Branch..."
      },
      {
        "command": "lakebaseSync.renameBranch",
        "title": "Rename Branch..."
      },
      {
        "command": "lakebaseSync.mergeBranch",
        "title": "Merge..."
      },
      {
        "command": "lakebaseSync.commitSignedOff",
        "title": "Commit (Signed Off)"
      },
      {
        "command": "lakebaseSync.commitStagedSignedOff",
        "title": "Commit Staged (Signed Off)"
      },
      {
        "command": "lakebaseSync.commitAllSignedOff",
        "title": "Commit All (Signed Off)"
      },
      {
        "command": "lakebaseSync.createProject",
        "title": "Lakebase: Create New Project",
        "icon": "$(add)"
      },
      {
        "command": "lakebaseSync.startRunner",
        "title": "Lakebase: Start CI Runner"
      },
      {
        "command": "lakebaseSync.stopRunner",
        "title": "Lakebase: Stop CI Runner"
      },
      {
        "command": "lakebaseSync.refreshRunner",
        "title": "Refresh CI Runner",
        "icon": "$(refresh)"
      },
      {
        "command": "lakebaseSync.createLakebaseBranchForGit",
        "title": "Lakebase: Create Branch from Production",
        "icon": "$(add)"
      },
      {
        "command": "lakebaseSync.deleteLakebaseBranch",
        "title": "Lakebase: Delete Branch",
        "icon": "$(trash)"
      },
      {
        "command": "lakebaseSync.createTag",
        "title": "Create Tag"
      },
      {
        "command": "lakebaseSync.deleteTag",
        "title": "Delete Tag"
      },
      {
        "command": "lakebaseSync.deleteRemoteTag",
        "title": "Delete Remote Tag"
      },
      {
        "command": "lakebaseSync.stashStaged",
        "title": "Stash Staged"
      },
      {
        "command": "lakebaseSync.stashIncludeUntracked",
        "title": "Stash (Include Untracked)"
      },
      {
        "command": "lakebaseSync.viewStash",
        "title": "View Stash..."
      },
      {
        "command": "lakebaseSync.stashApply",
        "title": "Apply Stash..."
      },
      {
        "command": "lakebaseSync.stashApplyLatest",
        "title": "Apply Latest Stash"
      },
      {
        "command": "lakebaseSync.stashPopLatest",
        "title": "Pop Latest Stash"
      },
      {
        "command": "lakebaseSync.stashDrop",
        "title": "Drop Stash..."
      },
      {
        "command": "lakebaseSync.stashDropAll",
        "title": "Drop All Stashes..."
      },
      {
        "command": "lakebaseSync.createWorktree",
        "title": "Create Worktree"
      },
      {
        "command": "lakebaseSync.removeWorktree",
        "title": "Delete Worktree"
      },
      {
        "command": "lakebaseSync.pullRebase",
        "title": "Pull (Rebase)"
      },
      {
        "command": "lakebaseSync.pullFrom",
        "title": "Pull from..."
      },
      {
        "command": "lakebaseSync.pushTo",
        "title": "Push to..."
      },
      {
        "command": "lakebaseSync.fetchPrune",
        "title": "Fetch (Prune)"
      },
      {
        "command": "lakebaseSync.fetchAll",
        "title": "Fetch From All Remotes"
      },
      {
        "command": "lakebaseSync.abortRebase",
        "title": "Abort Rebase"
      },
      {
        "command": "lakebaseSync.rebaseBranch",
        "title": "Rebase Branch..."
      },
      {
        "command": "lakebaseSync.createBranchFrom",
        "title": "Create Branch From..."
      },
      {
        "command": "lakebaseSync.deleteRemoteBranch",
        "title": "Delete Remote Branch..."
      },
      {
        "command": "lakebaseSync.addRemote",
        "title": "Add Remote..."
      },
      {
        "command": "lakebaseSync.removeRemote",
        "title": "Remove Remote..."
      },
      {
        "command": "lakebaseSync.showPrSchemaDiff",
        "title": "View PR Schema Diff",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "lakebaseSync.refreshPrStatus",
        "title": "Refresh PR Status",
        "icon": "$(refresh)"
      },
      {
        "command": "lakebaseSync.mergePullRequest",
        "title": "Merge Pull Request",
        "icon": "$(git-merge)"
      },
      {
        "command": "lakebaseSync.clone",
        "title": "Clone"
      },
      {
        "command": "lakebaseSync.showGitOutput",
        "title": "Show Git Output",
        "icon": "$(history)"
      },
      {
        "command": "lakebaseSync.toggleChangesList",
        "title": "View as List",
        "icon": "$(list-flat)"
      },
      {
        "command": "lakebaseSync.toggleChangesTree",
        "title": "View as Tree",
        "icon": "$(list-tree)"
      }
    ],
    "submenus": [
      { "id": "lakebaseSync.commitMenu", "label": "Commit" },
      { "id": "lakebaseSync.changesMenu", "label": "Changes" },
      { "id": "lakebaseSync.pullPushMenu", "label": "Pull, Push" },
      { "id": "lakebaseSync.branchMenu", "label": "Branch" },
      { "id": "lakebaseSync.stashMenu", "label": "Stash" },
      { "id": "lakebaseSync.tagsMenu", "label": "Tags" },
      { "id": "lakebaseSync.remoteMenu", "label": "Remote" },
      { "id": "lakebaseSync.worktreeMenu", "label": "Worktrees" },
      { "id": "lakebaseSync.lakebaseMenu", "label": "Lakebase" }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "lakebaseSync.publishBranch",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@1"
        },
        {
          "command": "lakebaseSync.commit",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@2"
        },
        {
          "command": "lakebaseSync.createPullRequest",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@3"
        },
        {
          "command": "lakebaseSync.refreshBranches",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@4"
        },
        {
          "command": "lakebaseSync.reviewBranch",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@5"
        },
        {
          "command": "lakebaseSync.createUnifiedBranch",
          "when": "scmProvider == lakebaseUnified && !lakebaseSync.onFeatureBranch",
          "group": "navigation@6"
        },
        {
          "command": "lakebaseSync.showBranchDiff",
          "when": "scmProvider == lakebaseUnified",
          "group": "navigation@7"
        },
        {
          "command": "lakebaseSync.pull",
          "when": "scmProvider == lakebaseUnified",
          "group": "1_top@1"
        },
        {
          "command": "lakebaseSync.push",
          "when": "scmProvider == lakebaseUnified",
          "group": "1_top@2"
        },
        {
          "command": "lakebaseSync.clone",
          "when": "scmProvider == lakebaseUnified",
          "group": "1_top@3"
        },
        {
          "command": "lakebaseSync.switchBranchPicker",
          "when": "scmProvider == lakebaseUnified",
          "group": "1_top@4"
        },
        {
          "command": "lakebaseSync.fetch",
          "when": "scmProvider == lakebaseUnified",
          "group": "1_top@5"
        },
        {
          "submenu": "lakebaseSync.commitMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@1"
        },
        {
          "submenu": "lakebaseSync.changesMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@2"
        },
        {
          "submenu": "lakebaseSync.pullPushMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@3"
        },
        {
          "submenu": "lakebaseSync.branchMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@4"
        },
        {
          "submenu": "lakebaseSync.stashMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@5"
        },
        {
          "submenu": "lakebaseSync.tagsMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@6"
        },
        {
          "submenu": "lakebaseSync.remoteMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@7"
        },
        {
          "submenu": "lakebaseSync.worktreeMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@8"
        },
        {
          "submenu": "lakebaseSync.lakebaseMenu",
          "when": "scmProvider == lakebaseUnified",
          "group": "2_submenus@9"
        },
        {
          "command": "lakebaseSync.showGitOutput",
          "when": "scmProvider == lakebaseUnified",
          "group": "3_misc@1"
        }
      ],
      "lakebaseSync.commitMenu": [
        { "command": "lakebaseSync.commit", "group": "1_commit@1" },
        { "command": "lakebaseSync.commitStaged", "group": "1_commit@2" },
        { "command": "lakebaseSync.commitAll", "group": "1_commit@3" },
        { "command": "lakebaseSync.undoLastCommit", "group": "1_commit@4" },
        { "command": "lakebaseSync.abortRebase", "group": "1_commit@5", "when": "lakebaseSync.isRebasing" },
        { "command": "lakebaseSync.commitAmend", "group": "2_amend@1" },
        { "command": "lakebaseSync.commitStagedAmend", "group": "2_amend@2" },
        { "command": "lakebaseSync.commitAllAmend", "group": "2_amend@3" },
        { "command": "lakebaseSync.commitSignedOff", "group": "3_signed@1" },
        { "command": "lakebaseSync.commitStagedSignedOff", "group": "3_signed@2" },
        { "command": "lakebaseSync.commitAllSignedOff", "group": "3_signed@3" }
      ],
      "lakebaseSync.changesMenu": [
        { "command": "lakebaseSync.stageAll", "group": "1_changes@1", "title": "Stage All Changes" },
        { "command": "lakebaseSync.unstageAll", "group": "1_changes@2", "title": "Unstage All Changes" },
        { "command": "lakebaseSync.discardAllChanges", "group": "1_changes@3", "title": "Discard All Changes" }
      ],
      "lakebaseSync.pullPushMenu": [
        { "command": "lakebaseSync.sync", "group": "1_sync@1" },
        { "command": "lakebaseSync.pull", "group": "2_pull@1" },
        { "command": "lakebaseSync.pullRebase", "group": "2_pull@2" },
        { "command": "lakebaseSync.pullFrom", "group": "2_pull@3" },
        { "command": "lakebaseSync.push", "group": "3_push@1" },
        { "command": "lakebaseSync.pushTo", "group": "3_push@2" },
        { "command": "lakebaseSync.fetch", "group": "4_fetch@1" },
        { "command": "lakebaseSync.fetchPrune", "group": "4_fetch@2" },
        { "command": "lakebaseSync.fetchAll", "group": "4_fetch@3" }
      ],
      "lakebaseSync.branchMenu": [
        { "command": "lakebaseSync.mergeBranch", "group": "1_merge@1" },
        { "command": "lakebaseSync.rebaseBranch", "group": "1_merge@2" },
        { "command": "lakebaseSync.createUnifiedBranch", "group": "2_create@1" },
        { "command": "lakebaseSync.createBranchFrom", "group": "2_create@2" },
        { "command": "lakebaseSync.renameBranch", "group": "3_manage@1" },
        { "command": "lakebaseSync.deleteBranch", "group": "3_manage@2" },
        { "command": "lakebaseSync.deleteRemoteBranch", "group": "3_manage@3" },
        { "command": "lakebaseSync.publishBranch", "group": "4_publish@1" }
      ],
      "lakebaseSync.stashMenu": [
        { "command": "lakebaseSync.stash", "group": "1_stash@1" },
        { "command": "lakebaseSync.stashIncludeUntracked", "group": "1_stash@2" },
        { "command": "lakebaseSync.stashStaged", "group": "1_stash@3" },
        { "command": "lakebaseSync.stashApplyLatest", "group": "2_apply@1" },
        { "command": "lakebaseSync.stashApply", "group": "2_apply@2" },
        { "command": "lakebaseSync.stashPopLatest", "group": "3_pop@1" },
        { "command": "lakebaseSync.stashPop", "group": "3_pop@2" },
        { "command": "lakebaseSync.stashDrop", "group": "4_drop@1" },
        { "command": "lakebaseSync.stashDropAll", "group": "4_drop@2" },
        { "command": "lakebaseSync.viewStash", "group": "5_view@1" }
      ],
      "lakebaseSync.tagsMenu": [
        { "command": "lakebaseSync.createTag", "group": "1_tags@1" },
        { "command": "lakebaseSync.deleteTag", "group": "1_tags@2" },
        { "command": "lakebaseSync.deleteRemoteTag", "group": "1_tags@3" }
      ],
      "lakebaseSync.remoteMenu": [
        { "command": "lakebaseSync.addRemote", "group": "1_remote@1" },
        { "command": "lakebaseSync.removeRemote", "group": "1_remote@2" }
      ],
      "lakebaseSync.worktreeMenu": [
        { "command": "lakebaseSync.createWorktree", "group": "1_worktree@1" },
        { "command": "lakebaseSync.listWorktrees", "group": "1_worktree@2" },
        { "command": "lakebaseSync.removeWorktree", "group": "1_worktree@3" }
      ],
      "lakebaseSync.lakebaseMenu": [
        { "command": "lakebaseSync.healthCheck", "group": "1_lakebase@1" },
        { "command": "lakebaseSync.openInConsole", "group": "1_lakebase@2" },
        { "command": "lakebaseSync.showBranchDiff", "group": "1_lakebase@3" },
        { "command": "lakebaseSync.showPrSchemaDiff", "group": "2_pr@1" },
        { "command": "lakebaseSync.mergePullRequest", "group": "2_pr@2" },
        { "command": "lakebaseSync.refreshPrStatus", "group": "2_pr@3" }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "lakebaseSync.stageAll",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == code",
          "group": "inline"
        },
        {
          "command": "lakebaseSync.unstageAll",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == staged",
          "group": "inline"
        },
        {
          "command": "lakebaseSync.mergePullRequest",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == pr && lakebaseSync.hasPR",
          "group": "inline@1"
        },
        {
          "command": "lakebaseSync.showPrSchemaDiff",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == pr && lakebaseSync.hasPR",
          "group": "inline@2"
        },
        {
          "command": "lakebaseSync.refreshPrStatus",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == pr && lakebaseSync.hasPR",
          "group": "inline@3"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "lakebaseSync.stageFile",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == code",
          "group": "inline@1"
        },
        {
          "command": "lakebaseSync.discardChanges",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == code",
          "group": "inline@2"
        },
        {
          "command": "lakebaseSync.unstageFile",
          "when": "scmProvider == lakebaseUnified && scmResourceGroup == staged",
          "group": "inline@1"
        }
      ],
      "view/title": [
        {
          "command": "lakebaseSync.refreshRunner",
          "when": "view == lakebaseRunner",
          "group": "navigation@1"
        },
        {
          "command": "lakebaseSync.connectWorkspace",
          "when": "view == lakebaseBranches",
          "group": "navigation@1"
        },
        {
          "command": "lakebaseSync.refreshBranches",
          "when": "view == lakebaseBranches",
          "group": "navigation@2"
        },
        {
          "command": "lakebaseSync.toggleChangesTree",
          "when": "view == lakebaseChanges && !lakebaseChanges.viewAsTree",
          "group": "navigation@0"
        },
        {
          "command": "lakebaseSync.toggleChangesList",
          "when": "view == lakebaseChanges && lakebaseChanges.viewAsTree",
          "group": "navigation@0"
        },
        {
          "command": "lakebaseSync.commit",
          "when": "view == lakebaseChanges",
          "group": "navigation@1"
        },
        {
          "command": "lakebaseSync.publishBranch",
          "when": "view == lakebaseChanges",
          "group": "navigation@2"
        },
        {
          "command": "lakebaseSync.createPullRequest",
