        },
        "lakebaseSync.autoCreateBranch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically create Lakebase branch on git checkout"
        },
        "lakebaseSync.autoRefreshCredentials": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh database credentials in background"
        },
        "lakebaseSync.migrationPath": {
          "type": "string",
          "default": "src/main/resources/db/migration",
          "description": "Path to Flyway migration files relative to workspace root"
        },
        "lakebaseSync.showUnifiedRepo": {
          "type": "boolean",
          "default": true,
          "description": "Show Unified Repo in SCM"
        },
        "lakebaseSync.productionReadOnly": {
