# Copy to .env and fill in. Do not commit .env.
# This demo uses Lakebase. Use Lakebase/Databricks config only.

# --- Lakebase (required for this demo) ---
# DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
# LAKEBASE_PROJECT_ID=your_lakebase_project_id
# Local CLI auth: `databricks auth login` (OAuth) — no token needed for local use.
# For GitHub Actions and set-repo-secrets.sh set DATABRICKS_TOKEN. After `databricks auth login`, run: databricks tokens create --comment "CI" --lifetime-seconds 2592000

# --- App (hook may guide; set for the current branch) ---
# SPRING_DATASOURCE_URL=jdbc:postgresql://...
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# --- Lakebase branch cleanup (for scripts/delete-lakebase-branches.sh) ---
# LAKEBASE_PR_NUM=7          # PR number → deletes ci-pr-7
# LAKEBASE_BRANCH=customer-entity   # Git branch name → deletes that Lakebase branch
