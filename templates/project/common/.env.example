# Lakebase project configuration
# Copy to .env and set your values, or let the post-checkout hook populate them.

DATABRICKS_HOST=
LAKEBASE_PROJECT_ID=

# Optional: git branch that should behave like main/master for this project
# (when not on a default-named branch). Set if your repo uses a prefixed
# trunk branch (e.g. psa-sandbox monorepo conventions).
# LAKEBASE_TRUNK_BRANCH=

# Optional: git branch that should be paired with the Lakebase `staging` branch.
# If set, checking out this git branch points .env at the `staging` Lakebase
# branch (which must be created by other means — it is not auto-created).
# LAKEBASE_STAGING_BRANCH=

# Connection (auto-populated by post-checkout hook)
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# DATABASE_URL=
