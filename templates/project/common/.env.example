# Lakebase project configuration
# Copy to .env and set your values, or let the post-checkout hook populate them.

DATABRICKS_HOST=
LAKEBASE_PROJECT_ID=

# Optional: git branch that should behave like main/master for this project
# (when not on a default-named branch). Set if your repo uses a prefixed
# trunk branch (e.g. psa-sandbox monorepo conventions).
# LAKEBASE_TRUNK_BRANCH=

# Optional: git branch that should be paired with the Lakebase `staging` branch.
# If set, checking out this git branch points .env at the `staging` Lakebase
# branch (which must be created by other means — it is not auto-created).
# LAKEBASE_STAGING_BRANCH=

# Optional: scopes the branch-tree sidebar to this project's branches only.
# In monorepos, the repo contains branches from many unrelated projects/users.
# Setting this to a common prefix (e.g. `user/project-`) hides the rest.
# The current branch is always shown regardless of this filter.
# LAKEBASE_GIT_BRANCH_PREFIX=

# Optional: forces new feature branches to fork from this Lakebase branch.
# Default behavior (when this is unset) is git-like: new branches fork
# from whichever Lakebase branch you were just on, so checking out a new
# feature while on `staging` forks it from staging. Set this to a fixed
# value (e.g. `staging`) if you want new features to ALWAYS fork from
# that branch regardless of where you were.
# LAKEBASE_BASE_BRANCH=

# Connection (auto-populated by post-checkout hook)
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=
# DATABASE_URL=
